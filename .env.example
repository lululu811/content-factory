# content-factory 环境变量样例
# 复制为 .env 后按需取消注释。任何未配置的 token 都将自动降级到 mock 模式,不会报错。
# 真实 token 请放 ~/.zshrc 或 ~/.bashrc,不要提交到 git。

# ───── 数据源 ─────
# Tushare pro_api() token(https://tushare.pro/register)
# CF_TUSHARE_TOKEN=

# myMCP 兼容端点(如需替换 Tushare 直连,启用 JSON-RPC 后端)
# CF_TUSHARE_BASE_URL=https://<your-myMCP-host>/mcp/token=<your-token>

# BibiGPT 视频/音频摘要(https://bibigpt.co)
# CF_BIBIGPT_TOKEN=

# ───── 多模态生成 ─────
# MiniMax(妙想)图片/视频/音乐/语音
# CF_MINIMAX_API_KEY=
# CF_MINIMAX_GROUP_ID=

# ───── 专业搜索 ─────
# dataPro 学术/工商/风险/股票/新闻检索
# CF_DATAPRO_TOKEN=

# ───── 外部服务(本地)─────
# B站字幕/弹幕/UP主动态(对接 bilibili_toolkit,默认 http://127.0.0.1:8100)
# CF_BILIBILI_URL=
# CF_BILIBILI_API_KEY=

# TrendRadar SQLite 目录(默认 /Users/chenlei/001_project/TrendRadar/output/rss)
# CF_TRENDRADAR_DB_DIR=/path/to/TrendRadar/output/rss

# RAG 知识库 API(默认 http://127.0.0.1:8002)
# CF_KNOWLEDGE_URL=

# ───── 发布 ─────
# 微信公众号 AppID/Secret(https://mp.weixin.qq.com)
# CF_WECHAT_APPID=
# CF_WECHAT_SECRET=

# ───── 多租户存储 ─────
# 启用 PostgreSQL 后端(未设置走内存后端)
# CF_DATABASE_URL=postgresql://user:pass@localhost:5432/content_factory

# ───── 可观测性 ─────
# 设为 1 开启 OpenTelemetry ConsoleSpanExporter
# CF_TRACE_CONSOLE=0

# ───── 工作流根目录(供脚本使用)─────
# CF_ROOT=/path/to/content-factory
